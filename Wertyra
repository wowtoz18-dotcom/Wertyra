-- Функция для создания страниц
local function createPage(name)
    local page = Instance.new("Frame")
    page.Size = UDim2.new(1, 0, 1, 0)
    page.BackgroundTransparency = 1
    page.Visible = false
    page.ZIndex = 2
    page.Parent = container
    
    -- Заголовок внутри страницы
    local pTitle = Instance.new("TextLabel")
    pTitle.Size = UDim2.new(1, 0, 0, 20)
    pTitle.BackgroundTransparency = 1
    pTitle.Text = name:upper() .. " FUNCTIONS"
    pTitle.TextColor3 = Color3.fromRGB(150, 140, 180)
    pTitle.Font = Enum.Font.GothamBold
    pTitle.TextSize = 13
    pTitle.TextXAlignment = Enum.TextXAlignment.Left
    pTitle.ZIndex = 3
    pTitle.Parent = page
    
    -- Пример пустого чекбокса/кнопки для красоты
    local placeholder = Instance.new("TextLabel")
    placeholder.Size = UDim2.new(1, 0, 0, 100)
    placeholder.Position = UDim2.new(0, 0, 0, 40)
    placeholder.BackgroundTransparency = 1
    placeholder.Text = "[ Ожидание добавления скриптов... ]"
    placeholder.TextColor3 = Color3.fromRGB(80, 75, 100)
    placeholder.Font = Enum.Font.GothamItalic
    placeholder.TextSize = 14
    placeholder.ZIndex = 3
    placeholder.Parent = page

    pages[name] = page
end

-- Переключение вкладок
local function switchTab(tabName, button)
    for _, p in pairs(pages) do p.Visible = false end
    if pages[tabName] then pages[tabName].Visible = true end
    
    -- Сброс цвета остальных кнопок (визуальный отклик)
    for _, child in ipairs(sidebar:GetChildren()) do
        if child:IsA("TextButton") then
            TweenService:Create(child, TweenInfo.new(0.2), {TextColor3 = Color3.fromRGB(160, 160, 170), BackgroundColor3 = Color3.fromRGB(15, 12, 28)}):Play()
        end
    end
    -- Подсветка активной кнопки
    TweenService:Create(button, TweenInfo.new(0.2), {TextColor3 = Color3.fromRGB(255, 255, 255), BackgroundColor3 = Color3.fromRGB(45, 30, 80)}):Play()
end

-- Генерация кнопок меню
for i, tabName in ipairs(tabs) do
    createPage(tabName)
    
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 120, 0, 32)
    btn.BackgroundColor3 = Color3.fromRGB(15, 12, 28)
    btn.Text = "  " .. tabName
    btn.TextColor3 = Color3.fromRGB(160, 160, 170)
    btn.Font = Enum.Font.GothamMedium
    btn.TextSize = 13
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.ZIndex = 3
    btn.Parent = sidebar
    
    local bCorner = Instance.new("UICorner")
    bCorner.CornerRadius = UDim.new(0, 6)
    bCorner.Parent = btn
    
    btn.MouseButton1Click:Connect(function()
        switchTab(tabName, btn)
    end)
    
    -- Открываем первую вкладку по умолчанию
    if i == 1 then
        switchTab(tabName, btn)
    end
end


-- [[ ЦИКЛ АНИМАЦИИ (ЗВЕЗДЫ + ДИНАМИЧЕСКИЙ ХУД) ]]
RunService.RenderStepped:Connect(function()
    -- Бег звёзд влево
    for _, starData in ipairs(stars) do
        local star = starData.obj
        local newX = star.Position.X.Scale - starData.speed
        if newX < 0 then 
            newX = 1
            star.Position = UDim2.new(newX, 0, math.random(), 0)
        else
            star.Position = UDim2.new(newX, 0, star.Position.Y.Scale, 0)
        end
    end
    
    -- Плавное RGB переливание неона вокруг меню
    local hue = (tick() % 6) / 6
    uiStroke.Color = Color3.fromHSV(hue, 0.65, 0.9)
end)
