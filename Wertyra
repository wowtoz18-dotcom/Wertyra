    bar.Size             = UDim2.new(0, 4, 0.7, 0)
    bar.Position         = UDim2.new(0, 8, 0.15, 0)
    bar.BackgroundColor3 = CONFIG.AccentColor
    bar.BorderSizePixel  = 0; bar.ZIndex = 201
    bar.Parent = n
    Instance.new("UICorner", bar).CornerRadius = UDim.new(0,4)

    local lbl = Instance.new("TextLabel")
    lbl.Size            = UDim2.new(1,-20,1,0)
    lbl.Position        = UDim2.new(0,18,0,0)
    lbl.BackgroundTransparency = 1
    lbl.Text            = msg
    lbl.TextColor3      = Color3.new(1,1,1)
    lbl.TextScaled      = true
    lbl.Font            = Enum.Font.Gotham
    lbl.TextXAlignment  = Enum.TextXAlignment.Left
    lbl.ZIndex          = 201
    lbl.Parent          = n

    tween(n, {Position = UDim2.new(0.5,-130,1,-62)}, 0.4, Enum.EasingStyle.Back)
    task.delay(duration, function()
        tween(n, {Position = UDim2.new(0.5,-130,1,10)}, 0.35)
        task.delay(0.4, function() n:Destroy() end)
    end)
end

