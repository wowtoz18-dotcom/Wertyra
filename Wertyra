--  CLICK VFX ‚ÄĒ ripple ring on mouse click
-- ============================================================
local function spawnRipple(x, y)
    if not CONFIG.ClickVfx then return end

    local container = ScreenGui

    -- Ring
    local ring = Instance.new("Frame")
    ring.Size             = UDim2.new(0, CONFIG.ClickSize * 0.3, 0, CONFIG.ClickSize * 0.3)
    ring.Position         = UDim2.new(0, x - CONFIG.ClickSize*0.15, 0, y - CONFIG.ClickSize*0.15)
    ring.BackgroundTransparency = 1
    ring.BorderSizePixel  = 0
    ring.ZIndex           = 100
    ring.Parent           = container
    Instance.new("UICorner", ring).CornerRadius = UDim.new(0.5, 0)

    local stroke = Instance.new("UIStroke", ring)
    stroke.Color       = CONFIG.ClickColor
    stroke.Thickness   = 2.5
    stroke.Transparency = 0

    -- Dot
    local dot = Instance.new("Frame")
    dot.Size             = UDim2.new(0, 8, 0, 8)
    dot.Position         = UDim2.new(0, x - 4, 0, y - 4)
    dot.BackgroundColor3 = CONFIG.ClickColor
    dot.BorderSizePixel  = 0
    dot.ZIndex           = 101
    dot.Parent           = container
    Instance.new("UICorner", dot).CornerRadius = UDim.new(0.5, 0)

    local sz = CONFIG.ClickSize
    local dur = CONFIG.ClickDuration

    tween(ring, {
        Size     = UDim2.new(0, sz, 0, sz),
        Position = UDim2.new(0, x - sz/2, 0, y - sz/2),
    }, dur, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    tween(stroke, {Transparency = 1}, dur)
    tween(dot, {BackgroundTransparency = 1, Size = UDim2.new(0,0,0,0),
        Position = UDim2.new(0, x, 0, y)}, dur * 0.6)

    game:GetService("Debris"):AddItem(ring, dur + 0.1)
    game:GetService("Debris"):AddItem(dot,  dur + 0.1)
end

-- Second, bigger ring for double-pulse feel
local function spawnRipple2(x, y)
    if not CONFIG.ClickVfx then return end
    task.delay(0.08, function()
        local sz = CONFIG.ClickSize * 1.6
        local dur = CONFIG.ClickDuration * 1.2
        local ring2 = Instance.new("Frame")
        ring2.Size             = UDim2.new(0, sz*0.15, 0, sz*0.15)
        ring2.Position         = UDim2.new(0, x - sz*0.075, 0, y - sz*0.075)
        ring2.BackgroundTransparency = 1
        ring2.BorderSizePixel  = 0
        ring2.ZIndex           = 99
        ring2.Parent           = ScreenGui
        Instance.new("UICorner", ring2).CornerRadius = UDim.new(0.5, 0)
        local s2 = Instance.new("UIStroke", ring2)
        s2.Color       = CONFIG.AccentColor2
        s2.Thickness   = 1.5
        s2.Transparency = 0.3
        tween(ring2, {Size = UDim2.new(0,sz,0,sz), Position = UDim2.new(0,x-sz/2,0,y-sz/2)}, dur)
        tween(s2, {Transparency = 1}, dur)
        game:GetService("Debris"):AddItem(ring2, dur + 0.1)
    end)
end

