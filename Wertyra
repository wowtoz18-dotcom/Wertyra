-- ============================================================
--  FPS & PING UPDATER
-- ============================================================
local fpsBuffer = {}
local fpsTimer  = 0

RunService.Heartbeat:Connect(function(dt)
    -- FPS rolling average
    table.insert(fpsBuffer, 1/dt)
    if #fpsBuffer > 20 then table.remove(fpsBuffer, 1) end
    local sum = 0
    for _, v in ipairs(fpsBuffer) do sum = sum + v end
    local fps = math.floor(sum/#fpsBuffer)
    FpsLabel.Text = fps .. " FPS"

    -- Color-code FPS
    if fps >= 50 then
        FpsLabel.TextColor3 = Color3.fromRGB(120,255,120)
    elseif fps >= 25 then
        FpsLabel.TextColor3 = Color3.fromRGB(255,210,60)
    else
        FpsLabel.TextColor3 = Color3.fromRGB(255,80,80)
    end

    -- Ping (Roblox internal stat)
    fpsTimer = fpsTimer + dt
    if fpsTimer >= 0.5 then
        fpsTimer = 0
        local ok, ping = pcall(function()
            return math.floor(game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValue())
        end)
        PingLabel.Text = (ok and ping or 0) .. " ms"
    end
end)

